escape ^]^]

# Ensure shells start as login shells (log ~/.bash_profile, etc.)
shell -$SHELL

startup_message off

vbell off
vbell_msg "BEEP"

nethack off
defscrollback 10000

hardstatus alwayslastline "%{= bW}%-w%{= rW}%n %t%{-}%+w %=%{= gW} %H %{= yW} %m/%d %C%a "

screen -t Emacs 0 emacs -nw
screen -t Ollama 2 bash -ilc 'ollama serve'
screen -t BUCKy 3 bash -ilc 'make -C  ~/src/perry-kundert-ca bucky-ollama'
screen -t Shell 1 bash -il
